# Local .terraform directories
.terraform/

# Terraform lock file — commit this if you want reproducible runs
# .terraform.lock.hcl

# .tfstate files — never commit state
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files — may contain secrets / env-specific values
# Keep terraform.tfvars.example for documentation purposes
*.tfvars
*.tfvars.json

# Ignore override files (used for local overrides, not for version control)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Plan output files
*.tfplan

# Environment files
.env
.env.*

# CLI configuration files
.terraformrc
terraform.rc
files.zip
